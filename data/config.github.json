{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-v4-flash",
    "api_key_env": "DEEPSEEK_API_KEY",
    "languages": ["zh"],
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 2,
    "enrichment_concurrency": 1
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "xxx@qq.com",
    "sender_name": "AI 视频创作日报",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {"type": "repo_releases", "owner": "Comfy-Org", "repo": "ComfyUI", "enabled": true},
      {"type": "repo_releases", "owner": "Wan-Video", "repo": "Wan2.1", "enabled": true},
      {"type": "repo_releases", "owner": "Tencent-Hunyuan", "repo": "HunyuanVideo", "enabled": true},
      {"type": "repo_releases", "owner": "Lightricks", "repo": "LTX-Video", "enabled": true},
      {"type": "repo_releases", "owner": "THUDM", "repo": "CogVideo", "enabled": true},
      {"type": "repo_releases", "owner": "hpcaitech", "repo": "Open-Sora", "enabled": true},
      {"type": "repo_releases", "owner": "KwaiVGI", "repo": "LivePortrait", "enabled": true},
      {"type": "repo_releases", "owner": "Rudrabha", "repo": "Wav2Lip", "enabled": true},
      {"type": "repo_releases", "owner": "huggingface", "repo": "diffusers", "enabled": true},
      {"type": "repo_releases", "owner": "huggingface", "repo": "transformers", "enabled": true}
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 80
    },
    "rss": [
      {"name": "OpenAI News", "url": "https://openai.com/news/rss.xml", "enabled": true, "category": "ai-video-models"},
      {"name": "Hugging Face Blog", "url": "https://huggingface.co/blog/feed.xml", "enabled": true, "category": "ai-video-open-source"},
      {"name": "Google AI Blog", "url": "https://blog.google/technology/ai/rss/", "enabled": true, "category": "ai-video-models"},
      {"name": "Google DeepMind Blog", "url": "https://deepmind.google/blog/rss.xml", "enabled": true, "category": "ai-video-research"}
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {"subreddit": "StableDiffusion", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 25, "min_score": 20},
        {"subreddit": "comfyui", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 20, "min_score": 10},
        {"subreddit": "aivideo", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 20, "min_score": 10},
        {"subreddit": "generativeAI", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 15, "min_score": 15}
      ],
      "users": [],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": false,
      "users": ["runwayml", "pika_labs", "LumaLabsAI", "Kling_ai", "Hailuo_AI"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": ["text-to-video", "image-to-video", "video generation", "comfyui", "digital human", "lip sync", "wan", "sora"],
      "min_stars": 20,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {"wide_screen_mode": true},
        "header": {
          "title": {"tag": "plain_text", "content": "#{message_title}"},
          "template": "blue"
        },
        "body": {
          "elements": [
            {"tag": "markdown", "content": "AI 视频创作资讯雷达：#{result}\n重要资讯数量：#{important_items}/#{all_items}"},
            {"tag": "hr"},
            {"tag": "markdown", "content": "#{summary}"}
          ]
        }
      }
    },
    "headers": ""
  }
}
