{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-v4-flash",
    "api_key_env": "DEEPSEEK_API_KEY",
    "languages": ["zh"],
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 2,
    "enrichment_concurrency": 1
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "xxx@qq.com",
    "sender_name": "AI创作动漫日报",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {"type": "repo_releases", "owner": "comfyanonymous", "repo": "ComfyUI", "enabled": true},
      {"type": "repo_releases", "owner": "AUTOMATIC1111", "repo": "stable-diffusion-webui", "enabled": true},
      {"type": "repo_releases", "owner": "lllyasviel", "repo": "stable-diffusion-webui-forge", "enabled": true},
      {"type": "repo_releases", "owner": "Mikubill", "repo": "sd-webui-controlnet", "enabled": true},
      {"type": "repo_releases", "owner": "kohya-ss", "repo": "sd-scripts", "enabled": true},
      {"type": "repo_releases", "owner": "huggingface", "repo": "diffusers", "enabled": true},
      {"type": "repo_releases", "owner": "TencentARC", "repo": "PhotoMaker", "enabled": true},
      {"type": "repo_releases", "owner": "xinntao", "repo": "Real-ESRGAN", "enabled": true},
      {"type": "repo_releases", "owner": "Sanster", "repo": "IOPaint", "enabled": true}
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 80
    },
    "rss": [
      {"name": "Hugging Face Blog", "url": "https://huggingface.co/blog/feed.xml", "enabled": true, "category": "ai-creation-anime"},
      {"name": "Stability AI News", "url": "https://stability.ai/news?format=rss", "enabled": true, "category": "ai-art-generation"},
      {"name": "Civitai Articles", "url": "https://civitai.com/articles/rss", "enabled": true, "category": "ai-art-anime-models"}
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {"subreddit": "StableDiffusion", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 30, "min_score": 20},
        {"subreddit": "aiArt", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 25, "min_score": 10},
        {"subreddit": "AnimeART", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 25, "min_score": 10},
        {"subreddit": "WaifuDiffusion", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 20, "min_score": 5},
        {"subreddit": "comfyui", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 20, "min_score": 10}
      ],
      "users": [],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": false,
      "users": [],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": ["anime ai", "ai anime", "AI art", "AI illustration", "Stable Diffusion", "ComfyUI", "LoRA", "ControlNet", "character generation", "anime diffusion", "waifu diffusion", "image generation"],
      "min_stars": 20,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {"wide_screen_mode": true},
        "header": {
          "title": {"tag": "plain_text", "content": "#{message_title}"},
          "template": "blue"
        },
        "body": {
          "elements": [
            {"tag": "markdown", "content": "AI创作动漫资讯雷达：#{result}\n重要资讯数量：#{important_items}/#{all_items}"},
            {"tag": "hr"},
            {"tag": "markdown", "content": "#{summary}"}
          ]
        }
      }
    },
    "headers": ""
  }
}
